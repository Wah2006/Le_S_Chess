[gd_scene load_steps=4 format=3 uid="uid://gamescene"]

[ext_resource type="Script" path="res://scripts/game.gd" id="1"]
[ext_resource type="PackedScene" uid="uid://boardscene" path="res://scenes/Board.tscn" id="2"]

[node name="Game" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Header" type="HBoxContainer" parent="."]
layout_mode = 2
size_flags_vertical = 0

[node name="WhiteLabel" type="Label" parent="Header"]
layout_mode = 2
text = "White (Player 1) - Elo: 1200"

[node name="BlackLabel" type="Label" parent="Header"]
layout_mode = 2
text = "Black (Player 2) - Elo: 1200"

[node name="BoardContainer" type="CenterContainer" parent="."]
layout_mode = 2
size_flags_vertical = 3

[node name="Board" parent="BoardContainer" instance=ExtResource("2")]
layout_mode = 2

[node name="Footer" type="HBoxContainer" parent="."]
layout_mode = 2
size_flags_vertical = 0

[node name="NewGameBtn" type="Button" parent="Footer"]
layout_mode = 2
text = "New Game"

[node name="AudioPlayer" type="AudioStreamPlayer" parent="."]

[connection signal="pressed" from="Footer/NewGameBtn" to="." method="new_game"]